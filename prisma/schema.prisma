generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CharacterChainCreationStatus {
  NOT_STARTED
  PENDING
  SUBMITTED
  CONFIRMED
  FAILED
}

enum BattleOutcomeLedgerStatus {
  AWAITING_FIRST_SYNC
  LOCAL_ONLY_ARCHIVED
  PENDING
  SEALED
  COMMITTED
}

enum SettlementBatchStatus {
  SEALED
  PREPARED
  SUBMITTED
  CONFIRMED
  FAILED
}

enum SettlementSubmissionAttemptStatus {
  STARTED
  BROADCAST
  CONFIRMED
  FAILED
  TIMEOUT
}

enum ActiveZoneRunState {
  TRAVERSING
  AWAITING_BRANCH
  POST_BATTLE_PAUSE
}

enum ZoneRunTerminalStatus {
  COMPLETED
  FAILED
  ABANDONED
  EXPIRED
  SEASON_CUTOFF
}

model User {
  id         String      @id @default(cuid())
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  characters Character[]
}

model Character {
  id               String             @id @default(cuid())
  userId           String
  name             String
  level            Int                @default(1)
  exp              Int                @default(0)
  hp               Int
  hpMax            Int
  atk              Int
  def              Int
  spd              Int
  accuracyBP       Int
  evadeBP          Int
  playerAuthorityPubkey String?
  chainCharacterIdHex   String?                     @unique
  characterRootPubkey   String?                     @unique
  chainCreationStatus   CharacterChainCreationStatus @default(NOT_STARTED)
  chainCreationTxSignature String?
  chainCreatedAt        DateTime?
  chainCreationTs       BigInt?
  chainCreationSeasonId Int?
  lastReconciledEndNonce BigInt?
  lastReconciledStateHash String?
  lastReconciledBatchId BigInt?
  lastReconciledBattleTs BigInt?
  lastReconciledSeasonId Int?
  lastReconciledAt      DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillUnlocks     SkillUnlock[]
  equippedSkills   EquippedSkill[]
  equippedPassives EquippedPassive[]
  inventoryItems   InventoryItem[]
  battleRecords    BattleRecord[]
  battleOutcomes   BattleOutcomeLedger[]
  settlementBatches SettlementBatch[]
  provisionalProgress CharacterProvisionalProgress?
  activeZoneRun    ActiveZoneRun?
  closedZoneRuns   ClosedZoneRunSummary[]
  zoneRunActions   ZoneRunActionLog[]
  zoneRunMutations ZoneRunMutationDedup[]

  @@index([userId])
  @@index([chainCreationStatus])
}

model CharacterProvisionalProgress {
  id                    String    @id @default(cuid())
  characterId           String    @unique
  highestUnlockedZoneId Int
  highestClearedZoneId  Int
  zoneStatesJson        Json
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  character             Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([highestUnlockedZoneId, highestClearedZoneId])
}

model SkillUnlock {
  id          String    @id @default(cuid())
  characterId String
  skillId     String
  unlockedAt  DateTime  @default(now())
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, skillId])
  @@index([characterId])
}

model EquippedSkill {
  id          String    @id @default(cuid())
  characterId String
  slot        Int
  skillId     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, slot])
  @@index([characterId])
}

model EquippedPassive {
  id          String    @id @default(cuid())
  characterId String
  slot        Int
  passiveId   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, slot])
  @@index([characterId])
}

model InventoryItem {
  id          String    @id @default(cuid())
  characterId String
  itemId      String
  quantity    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, itemId])
  @@index([characterId])
}

model BattleRecord {
  id               String    @id @default(cuid())
  battleId         String    @unique
  characterId      String
  zoneRunId        String?
  zoneId           Int
  nodeId           String?
  subnodeId        String?
  enemyArchetypeId Int
  seed             Int
  playerInitialJson Json
  enemyInitialJson  Json
  playerFinalJson  Json?
  enemyFinalJson   Json?
  rewardEligible   Boolean   @default(true)
  winnerEntityId   String
  roundsPlayed     Int
  eventsJson       Json
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  character        Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId, createdAt])
  @@index([characterId, zoneId, enemyArchetypeId])
  @@index([characterId, zoneRunId, createdAt])
}

model BattleOutcomeLedger {
  id                   String                   @id @default(cuid())
  characterId          String
  battleId             String                   @unique
  zoneRunId            String?
  localSequence        BigInt
  battleNonce          BigInt?
  battleTs             BigInt
  seasonId             Int
  zoneId               Int
  enemyArchetypeId     Int
  zoneProgressDeltaJson Json
  settlementStatus     BattleOutcomeLedgerStatus @default(PENDING)
  sealedBatchId        String?
  committedAt          DateTime?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  character            Character                @relation(fields: [characterId], references: [id], onDelete: Cascade)
  sealedBatch          SettlementBatch?         @relation("SealedBattles", fields: [sealedBatchId], references: [id], onDelete: SetNull)

  @@unique([characterId, localSequence])
  @@unique([characterId, battleNonce])
  @@index([characterId, settlementStatus, localSequence])
  @@index([characterId, settlementStatus, battleNonce])
  @@index([sealedBatchId])
  @@index([characterId, zoneRunId, localSequence])
}

model ActiveZoneRun {
  id                String             @id @default(cuid())
  characterId       String             @unique
  zoneId            Int
  seasonId          Int
  topologyVersion   Int
  topologyHash      String
  state             ActiveZoneRunState
  currentNodeId     String
  stateJson         Json
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  character         Character          @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId, zoneId, state])
}

model ClosedZoneRunSummary {
  id                            String                @id @default(cuid())
  zoneRunId                     String                @unique
  characterId                   String
  zoneId                        Int
  seasonId                      Int
  topologyVersion               Int
  topologyHash                  String
  terminalStatus                ZoneRunTerminalStatus
  rewardedBattleCount           Int
  rewardedEncounterHistogramJson Json
  zoneProgressDeltaJson         Json
  createdAt                     DateTime              @default(now())
  updatedAt                     DateTime              @updatedAt
  closedAt                      DateTime
  character                     Character             @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId, createdAt])
  @@index([characterId, zoneId, terminalStatus])
}

model ZoneRunActionLog {
  id          String      @id @default(cuid())
  zoneRunId   String
  characterId String
  actionType  String
  nodeId      String?
  subnodeId   String?
  payloadJson Json
  createdAt   DateTime    @default(now())
  character   Character    @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([zoneRunId, createdAt])
  @@index([characterId, createdAt])
}

model ZoneRunMutationDedup {
  id          String   @id @default(cuid())
  characterId String
  requestKey  String
  actionType  String
  responseJson Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, requestKey])
  @@index([characterId, createdAt])
}

model SettlementBatch {
  id                        String                     @id @default(cuid())
  characterId               String
  batchId                   BigInt
  startNonce                BigInt
  endNonce                  BigInt
  battleCount               Int
  firstBattleTs             BigInt
  lastBattleTs              BigInt
  seasonId                  Int
  startStateHash            String
  endStateHash              String
  zoneProgressDeltaJson     Json
  encounterHistogramJson    Json
  optionalLoadoutRevision   Int?
  batchHash                 String
  schemaVersion             Int
  signatureScheme           Int
  status                    SettlementBatchStatus     @default(SEALED)
  failureCategory           String?
  failureCode               String?
  latestMessageSha256Hex    String?
  latestSignedTxSha256Hex   String?
  latestTransactionSignature String?
  preparedAt                DateTime?
  submittedAt               DateTime?
  confirmedAt               DateTime?
  failedAt                  DateTime?
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  character                 Character                 @relation(fields: [characterId], references: [id], onDelete: Cascade)
  sealedBattles             BattleOutcomeLedger[]     @relation("SealedBattles")
  submissionAttempts        SettlementSubmissionAttempt[]

  @@unique([characterId, batchId])
  @@unique([characterId, batchHash])
  @@index([characterId, status, batchId])
  @@index([characterId, startNonce, endNonce])
}

model SettlementSubmissionAttempt {
  id                       String                            @id @default(cuid())
  settlementBatchId        String
  attemptNumber            Int
  status                   SettlementSubmissionAttemptStatus @default(STARTED)
  messageSha256Hex         String?
  signedTransactionSha256Hex String?
  transactionSignature     String?
  rpcError                 String?
  createdAt                DateTime                          @default(now())
  updatedAt                DateTime                          @updatedAt
  submittedAt              DateTime?
  resolvedAt               DateTime?
  settlementBatch          SettlementBatch                   @relation(fields: [settlementBatchId], references: [id], onDelete: Cascade)

  @@unique([settlementBatchId, attemptNumber])
  @@index([settlementBatchId, status, attemptNumber])
}
